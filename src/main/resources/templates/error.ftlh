<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>You Died - Elden Ring Gallery</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>
<body class="death-body">

    <div class="death-container">
        <h1 class="death-text">YOU DIED</h1>
        
        <div class="mt-4">
            <h3 class="text-warning">${status!"Error"}</h3>
            <p class="fs-5 text-light">${error!"The path forward is obscured by fog."}</p>
        </div>

        <div class="mt-5">
            <a href="/" class="btn btn-gold btn-lg px-5">Return to Site of Grace</a>
        </div>
    </div>

</body>
</html>